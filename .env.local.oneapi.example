# ---------------------------------------------------------------------------
# VerseCraft：仅「AI 网关」片段示例（对接本地 one-api 等 OpenAI 兼容网关）
# 用法：复制下列行合并进仓库根目录的 .env.local，或运行 pnpm patch:env-local-ai
# 完整模板见 .env.example；数据库与 AUTH 等仍须按 docs/local-development.md 配置
# ---------------------------------------------------------------------------

AI_GATEWAY_PROVIDER="oneapi"
AI_GATEWAY_BASE_URL="http://127.0.0.1:3000"
AI_GATEWAY_API_KEY="在_one-api_控制台创建的令牌"

# Phase 1 推荐仅保留 3 个实际部署名：vc-main / vc-control / vc-reasoner。
# enhance 逻辑角色先保留兼容，默认映射到 vc-main（无需单独 vc-enhance）。
AI_MODEL_MAIN="vc-main"
AI_MODEL_CONTROL="vc-control"
AI_MODEL_ENHANCE="vc-main"
AI_MODEL_REASONER="vc-reasoner"

# 默认关闭叙事增强的实际触发（保留兼容代码路径）
AI_ENABLE_NARRATIVE_ENHANCEMENT="0"

# 在线链路预算建议（可按网关质量微调）
AI_CONTROL_PREFLIGHT_BUDGET_MS="400"
AI_LORE_RETRIEVAL_BUDGET_MS="600"
AI_STREAM_MODERATION_THROTTLE_MS="100"

# ---------------------------------------------------------------------------
# NPC 认知隔离（灰度 / 回滚）；默认均可省略（全开）
# VERSECRAFT_ENABLE_EPISTEMIC_GUARD=1
# VERSECRAFT_ENABLE_EPISTEMIC_VALIDATOR=1
# VERSECRAFT_ENABLE_NPC_RESIDUE=1
# VERSECRAFT_ENABLE_XINLAN_STRONG_MEMORY=1
# VERSECRAFT_EPISTEMIC_DEBUG_LOG=0
# 兼容旧名：VERSECRAFT_EPISTEMIC_POST_GUARD、VERSECRAFT_EPISTEMIC_RESIDUE_GAMEFEEL
# ---------------------------------------------------------------------------

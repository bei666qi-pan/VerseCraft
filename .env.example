# =============================================================================
# VerseCraft — environment template
# -----------------------------------------------------------------------------
# Local:  copy to `.env.local` and fill values (`.env.local` is gitignored).
# Coolify: add the same keys under Environment Variables (no file upload needed).
# Next.js loads `.env.local` automatically in dev/production Node runtime.
# =============================================================================

# --- Required (server fails fast on boot if missing) --------------------------
DATABASE_URL="postgresql://postgres:change_me@127.0.0.1:5432/versecraft"
AUTH_SECRET="replace_with_at_least_32_chars_random_secret"

# --- Auth / admin -------------------------------------------------------------
AUTH_TRUST_HOST="true"
# Local dev on port 666: set if NextAuth redirects break
# AUTH_URL="http://localhost:666"
ADMIN_PASSWORD="replace_with_strong_admin_password"
ALTCHA_HMAC_KEY="replace_with_random_hmac_key"

# Optional: HMAC for `/api/audit` client signatures (defaults to AUTH_SECRET if unset)
# AUDIT_HMAC_SECRET=""

# --- Redis (optional; rate limits fall back to in-memory if unset) ------------
REDIS_URL="redis://127.0.0.1:6379"

# --- Public build stamp (safe for browser; optional) --------------------------
# NEXT_PUBLIC_BUILD_ID="local-dev"
# BUILD_ID="coolify-build-123"

# --- Public compliance / legal footer (browser; optional overrides) ----------
# Defaults in code: domain versecraft.cn, ICP 湘ICP备2025143231号-2, MIIT 查询入口链接
# NEXT_PUBLIC_PRODUCT_NAME="VerseCraft（文界工坊）"
# NEXT_PUBLIC_OPERATING_SUBJECT="（填写营业执照名称）"
# NEXT_PUBLIC_CONTACT_EMAIL="support@versecraft.cn"
# NEXT_PUBLIC_CONTACT_PHONE="18163616407"
# NEXT_PUBLIC_CUSTOMER_WECHAT=""
# NEXT_PUBLIC_CUSTOMER_PUBLIC_ACCOUNT=""
# NEXT_PUBLIC_OFFICIAL_DOMAIN="versecraft.cn"
# NEXT_PUBLIC_OFFICIAL_SITE_URL="https://versecraft.cn"
# NEXT_PUBLIC_BEIAN_NUMBER="湘ICP备2025143231号-2"
# NEXT_PUBLIC_BEIAN_URL="https://beian.miit.gov.cn"
# NEXT_PUBLIC_LEGAL_EFFECTIVE_DATE="2025-03-25"
# NEXT_PUBLIC_IS_TEST_PERIOD="true"
# NEXT_PUBLIC_SHOW_MINORS="true"
# NEXT_PUBLIC_SHOW_AI_DISCLAIMER="true"

# --- Next.js dev --------------------------------------------------------------
# Comma-separated hosts for `allowedDevOrigins` (VPN/LAN IPs, etc.)
# NEXT_DEV_ALLOWED_ORIGINS=198.18.0.1

# --- AI (one-api / OpenAI-compatible gateway) ---------------------------------
# All LLM traffic goes through one gateway URL + key. Map upstream vendors in one-api, not in app code.
# Keys are SERVER-ONLY — never NEXT_PUBLIC_*.
AI_GATEWAY_PROVIDER="oneapi"
# Base URL: e.g. https://your-one-api.example.com (app appends /v1/chat/completions) or paste full .../chat/completions
AI_GATEWAY_BASE_URL="https://your-one-api.example.com"
AI_GATEWAY_API_KEY="replace_with_oneapi_token"
# Logical roles → model names as registered in one-api (opaque strings here)
AI_MODEL_MAIN="vc-main"
AI_MODEL_CONTROL="vc-control"
AI_MODEL_ENHANCE="vc-main"
AI_MODEL_REASONER="vc-reasoner"
# Player SSE fallback order (comma-separated): main, control, enhance, reasoner
# AI_PLAYER_ROLE_CHAIN="main,control"
# Optional overrides for task chains (defaults: memory→main, dev assist→reasoner)
# AI_MEMORY_PRIMARY_ROLE="main"
# AI_DEV_ASSIST_PRIMARY_ROLE="reasoner"
# AI_REQUEST_TIMEOUT_MS="60000"
# AI_TIMEOUT_MS="60000"
# AI_ENABLE_STREAM="true"
# AI_LOG_LEVEL="info"
# AI_MAX_RETRIES="2"
# AI_RETRY_COUNT="2"
# AI_CIRCUIT_FAILURE_THRESHOLD="4"
# AI_CIRCUIT_COOLDOWN_MS="60000"
# AI_OPERATION_MODE="full"
# AI_EXPOSE_ROUTING_HEADER="0"

# Latency / streaming (see docs/ai-gateway.md §7) — 0 = legacy behavior (no wall-clock cap / no throttle)
# AI_CONTROL_PREFLIGHT_BUDGET_MS="400"
# AI_LORE_RETRIEVAL_BUDGET_MS="600"
# AI_NARRATIVE_ENHANCE_BUDGET_MS="2800"
# AI_STREAM_MODERATION_THROTTLE_MS="100"
# AI_CHAT_ENABLE_DIAGNOSTICS="1"
# AI_CHAT_ENABLE_STATUS_FRAMES="1"
# AI_CHAT_ENABLE_RISK_LANE_SPLIT="1"
# AI_CHAT_ENABLE_LIGHTWEIGHT_FAST_PATH="1"
# AI_CHAT_ENABLE_PROMPT_SLIMMING="1"
# AI_CHAT_FASTLANE_SKIP_RUNTIME_PACKETS="1"
# AI_CHAT_TIERED_CONTEXT_BUILD="1"
# AI_CHAT_CONTROL_PREFLIGHT_BUDGET_MS_CAP="260"
# AI_CHAT_LORE_RETRIEVAL_BUDGET_MS_CAP="220"

# Router / online task hardening
# AI_PLAYER_CHAT_STREAM_INCLUDE_USAGE="1"
# AI_PLAYER_CHAT_MAX_ROLE_CANDIDATES="2"
# AI_PLAYER_CHAT_MAX_RETRIES="1"
# AI_ONLINE_SHORT_JSON_MAX_RETRIES="0"
# AI_ONLINE_SHORT_JSON_RELAX_RESPONSE_FORMAT="1"
# AI_ONLINE_SHORT_JSON_DISABLE_MAIN_FALLBACK="1"

# Frontend waiting UX / smoothing (A/B ready). 0 = 关闭节流主文案 + 副文案（回退旧「语义等待」行）
# NEXT_PUBLIC_CHAT_WAITING_UX="1"
# NEXT_PUBLIC_CHAT_STREAM_SMOOTHING_V2="1"
# NEXT_PUBLIC_CHAT_DIAGNOSTICS="1"
# NEXT_PUBLIC_CHAT_AUTO_PARAGRAPH="1"
# NEXT_PUBLIC_CHAT_AUTO_PARAGRAPH_MIN_CHARS="100"

# Player DM: stable system prefix memo invalidation (bump when static lore/rules change)
# VERSECRAFT_DM_STABLE_PROMPT_VERSION="1"
# Phase 7: /play 叙事系统调试浮层（客户端）；服务端变更集控制台日志
# NEXT_PUBLIC_VERSECRAFT_SYSTEMS_DEBUG="1"
# VERSECRAFT_DM_CHANGESET_DEBUG="1"
# Phase 6: 叙事咬合读档修复日志
# NEXT_PUBLIC_VERSECRAFT_NARRATIVE_DEBUG="1"
# Optional: two system messages (stable + dynamic) for PLAYER_CHAT — default single concatenated system
# AI_PLAYER_CHAT_SPLIT_SYSTEM="0"
# Narrative enhancement pipeline switch (Phase 1 default: disabled, logic kept for compatibility)
# AI_ENABLE_NARRATIVE_ENHANCEMENT="0"
# Optional: merge JSON into chat-completions body for vendor-specific fields (user, cache hints, etc.)
# AI_GATEWAY_MERGE_EXTRA_BODY="0"
# AI_GATEWAY_EXTRA_BODY_JSON="{\"user\":\"versecraft-dm-v1\"}"

# AI governance (cost / gate / cache) — see docs/ai-governance.md
# AI_RESPONSE_CACHE_ENABLED="1"
# VERSECRAFT_AI_CACHE_VERSION="1"
# AI_CACHE_TTL_CONTROL_SEC="50"
# AI_PREFLIGHT_MAX_PER_MINUTE="48"
# AI_ENHANCE_COOLDOWN_SEC="90"
# AI_ENHANCE_MAX_PER_HOUR="10"
# Optional: raise to tighten narrative enhancement gate (default 32 = historical)
# AI_ENHANCE_GATE_MIN_SCORE="32"

# --- Runtime / quotas ---------------------------------------------------------
MIGRATE_ON_BOOT="1"
RUNTIME_SCHEMA_ENSURE="1"
DAILY_TOKEN_LIMIT="50000"
DAILY_ACTION_LIMIT="200"

# --- Content safety (canonical names) -----------------------------------------
MODERATION_ENABLED="true"
MODERATION_PROVIDER="auto"
MODERATION_TIMEOUT_MS="3000"
MODERATION_FAIL_OPEN="true"
SECURITY_LOG_LEVEL="warn"

SECURITY_IP_LIMIT_PER_MINUTE="30"
SECURITY_SESSION_LIMIT_PER_MINUTE="24"
SECURITY_USER_LIMIT_PER_MINUTE="20"
SECURITY_HIGH_RISK_STRIKE_THRESHOLD="3"
SECURITY_TEMP_BLOCK_SECONDS="600"

# --- Baidu Sinan / 文本审核（服务端-only，禁止前端导出） --------------
# 本地 `.env.example` 只放占位；生产环境请在 Coolify 配置真实值（且只能注入到服务端运行环境）。
# 不允许使用 NEXT_PUBLIC_* 暴露任何 AK/SK 或鉴权信息。
BAIDU_SINAN_ENABLED="false"
BAIDU_SINAN_PROVIDER="baidu_text_censor"

# 仅用于服务端：AK/SK -> OAuth access_token（由代码自动换取并缓存，access_token 不落盘）
BAIDU_SINAN_API_KEY="your_baidu_api_key"
BAIDU_SINAN_SECRET_KEY="your_baidu_secret_key"
BAIDU_SINAN_AUTH_MODE="oauth_access_token"

# OAuth / 审核接口地址（可通过 env 切换以支持未来策略）
BAIDU_SINAN_TOKEN_URL="https://aip.baidubce.com/oauth/2.0/token"
BAIDU_SINAN_TEXT_CENSOR_URL="https://aip.baidubce.com/rest/2.0/solution/v1/text_censor/v2/user_defined"

# 网络保护（用于 AbortController 超时）
BAIDU_SINAN_TIMEOUT_MS="2500"
BAIDU_SINAN_CONNECT_TIMEOUT_MS="1200"

# 熔断（circuit breaker）
# 当外部文本审核连续失败达到阈值时，短时间内跳过外部调用，避免并发故障时拖垮整体服务。
# 私密场景建议 fail_soft；公开展示建议 fail_closed。
BAIDU_SINAN_CIRCUIT_FAILURE_THRESHOLD="3"
BAIDU_SINAN_CIRCUIT_WINDOW_MS="60000"
BAIDU_SINAN_CIRCUIT_COOLDOWN_MS="60000"

# stage gating（input/output/public）
BAIDU_SINAN_INPUT_ENABLED="true"
BAIDU_SINAN_OUTPUT_ENABLED="true"
BAIDU_SINAN_PUBLIC_CONTENT_ENABLED="true"

# 失败模式（失败时不合规处理策略：private=软失败，public=闭失败）
BAIDU_SINAN_FAIL_MODE_PRIVATE="fail_soft"
BAIDU_SINAN_FAIL_MODE_PUBLIC="fail_closed"

# 证据留痕/隐私
BAIDU_SINAN_LOG_RAW_TEXT="false"
BAIDU_SINAN_HASH_SALT="replace_me"

# 审核策略强度（实现中默认 balanced 不传 strategyId；strict/loose 可作为策略中心映射占位）
BAIDU_SINAN_STRICTNESS_PROFILE="balanced"

# --- VerseCraft Safety Engine (server-only) -----------------------------------
# Default: do NOT log raw user text. Enable only for emergency incident debugging.
VC_SAFETY_LOG_RAW_TEXT="false"
# Salt for hashing/fingerprinting user text in logs (do not reuse public salts).
VC_SAFETY_HASH_SALT="replace_me"

# --- Output safety (server-only) ------------------------------------------
# 外部文本审核不可用时的降级策略（私密输出更偏软降级；公开展示必须更严格）。
VC_OUTPUT_FAIL_MODE_PRIVATE="fail_soft"
VC_OUTPUT_FAIL_MODE_PUBLIC="fail_closed"

# Optional: persist safety audit events into DB (append-only). Default OFF.
# Recommended ON for production operations / investigations; still does NOT store raw user text by default.
VC_SAFETY_AUDIT_DB_ENABLED="false"

# Renamed / removed (do not use — set the MODERATION_* / SECURITY_LOG_LEVEL keys above instead):
# SECURITY_MODERATION_ENABLED, SECURITY_MODERATION_PROVIDER, SECURITY_MODERATION_TIMEOUT_MS,
# SECURITY_MODERATION_FAIL_OPEN, SECURITY_AUDIT_LOG_LEVEL, SECRET_KEY (use AUDIT_HMAC_SECRET or AUTH_SECRET)

# =============================================================================
# 附录：旧版 AI 环境变量（迁移用，不推荐新部署）
# -----------------------------------------------------------------------------
# 见 docs/ai-gateway.md#legacy-migration — 未来将移除代码内 id→角色 映射，请改用 AI_PLAYER_ROLE_CHAIN。
# AI_PLAYER_MODEL_CHAIN="deepseek-v3.2,glm-5-air"
# AI_MEMORY_MODEL="deepseek-v3.2"
# AI_ADMIN_MODEL="deepseek-reasoner"

# =============================================================================
# VerseCraft — environment template
# -----------------------------------------------------------------------------
# Local:  copy to `.env.local` and fill values (`.env.local` is gitignored).
# Coolify: add the same keys under Environment Variables (no file upload needed).
# Next.js loads `.env.local` automatically in dev/production Node runtime.
# =============================================================================

# --- Required (server fails fast on boot if missing) --------------------------
DATABASE_URL="postgresql://postgres:change_me@127.0.0.1:5432/versecraft"
AUTH_SECRET="replace_with_at_least_32_chars_random_secret"

# --- Auth / admin -------------------------------------------------------------
AUTH_TRUST_HOST="true"
# Local dev on port 666: set if NextAuth redirects break
# AUTH_URL="http://localhost:666"
ADMIN_PASSWORD="replace_with_strong_admin_password"
ALTCHA_HMAC_KEY="replace_with_random_hmac_key"

# Optional: HMAC for `/api/audit` client signatures (defaults to AUTH_SECRET if unset)
# AUDIT_HMAC_SECRET=""

# --- Redis (optional; rate limits fall back to in-memory if unset) ------------
REDIS_URL="redis://127.0.0.1:6379"

# --- Public build stamp (safe for browser; optional) --------------------------
# NEXT_PUBLIC_BUILD_ID="local-dev"
# BUILD_ID="coolify-build-123"

# --- Next.js dev --------------------------------------------------------------
# Comma-separated hosts for `allowedDevOrigins` (VPN/LAN IPs, etc.)
# NEXT_DEV_ALLOWED_ORIGINS=198.18.0.1

# --- AI (one-api / OpenAI-compatible gateway) ---------------------------------
# All LLM traffic goes through one gateway URL + key. Map upstream vendors in one-api, not in app code.
# Keys are SERVER-ONLY — never NEXT_PUBLIC_*.
AI_GATEWAY_PROVIDER="oneapi"
# Base URL: e.g. https://your-one-api.example.com (app appends /v1/chat/completions) or paste full .../chat/completions
AI_GATEWAY_BASE_URL="https://your-one-api.example.com"
AI_GATEWAY_API_KEY="replace_with_oneapi_token"
# Logical roles → model names as registered in one-api (opaque strings here)
AI_MODEL_MAIN="vc-main"
AI_MODEL_CONTROL="vc-control"
AI_MODEL_ENHANCE="vc-enhance"
AI_MODEL_REASONER="vc-reasoner"
# Player SSE fallback order (comma-separated): main, control, enhance, reasoner
# AI_PLAYER_ROLE_CHAIN="main,control"
# Optional overrides for task chains (defaults: memory→main, dev assist→reasoner)
# AI_MEMORY_PRIMARY_ROLE="main"
# AI_DEV_ASSIST_PRIMARY_ROLE="reasoner"
# AI_REQUEST_TIMEOUT_MS="60000"
# AI_TIMEOUT_MS="60000"
# AI_ENABLE_STREAM="true"
# AI_LOG_LEVEL="info"
# AI_MAX_RETRIES="2"
# AI_RETRY_COUNT="2"
# AI_CIRCUIT_FAILURE_THRESHOLD="4"
# AI_CIRCUIT_COOLDOWN_MS="60000"
# AI_OPERATION_MODE="full"
# AI_EXPOSE_ROUTING_HEADER="0"

# Latency / streaming (see docs/ai-gateway.md §7) — 0 = legacy behavior (no wall-clock cap / no throttle)
# AI_CONTROL_PREFLIGHT_BUDGET_MS="400"
# AI_NARRATIVE_ENHANCE_BUDGET_MS="2800"
# AI_STREAM_MODERATION_THROTTLE_MS="100"

# Player DM: stable system prefix memo invalidation (bump when static lore/rules change)
# VERSECRAFT_DM_STABLE_PROMPT_VERSION="1"
# Optional: two system messages (stable + dynamic) for PLAYER_CHAT — default single concatenated system
# AI_PLAYER_CHAT_SPLIT_SYSTEM="0"
# Optional: merge JSON into chat-completions body for vendor-specific fields (user, cache hints, etc.)
# AI_GATEWAY_MERGE_EXTRA_BODY="0"
# AI_GATEWAY_EXTRA_BODY_JSON="{\"user\":\"versecraft-dm-v1\"}"

# AI governance (cost / gate / cache) — see docs/ai-governance.md
# AI_RESPONSE_CACHE_ENABLED="1"
# VERSECRAFT_AI_CACHE_VERSION="1"
# AI_CACHE_TTL_CONTROL_SEC="50"
# AI_PREFLIGHT_MAX_PER_MINUTE="48"
# AI_ENHANCE_COOLDOWN_SEC="90"
# AI_ENHANCE_MAX_PER_HOUR="10"
# Optional: raise to tighten narrative enhancement gate (default 32 = historical)
# AI_ENHANCE_GATE_MIN_SCORE="32"

# --- Runtime / quotas ---------------------------------------------------------
MIGRATE_ON_BOOT="1"
RUNTIME_SCHEMA_ENSURE="1"
DAILY_TOKEN_LIMIT="50000"
DAILY_ACTION_LIMIT="200"

# --- Content safety (canonical names) -----------------------------------------
MODERATION_ENABLED="true"
MODERATION_PROVIDER="auto"
MODERATION_TIMEOUT_MS="3000"
MODERATION_FAIL_OPEN="true"
SECURITY_LOG_LEVEL="warn"

SECURITY_IP_LIMIT_PER_MINUTE="30"
SECURITY_SESSION_LIMIT_PER_MINUTE="24"
SECURITY_USER_LIMIT_PER_MINUTE="20"
SECURITY_HIGH_RISK_STRIKE_THRESHOLD="3"
SECURITY_TEMP_BLOCK_SECONDS="600"

# Renamed / removed (do not use — set the MODERATION_* / SECURITY_LOG_LEVEL keys above instead):
# SECURITY_MODERATION_ENABLED, SECURITY_MODERATION_PROVIDER, SECURITY_MODERATION_TIMEOUT_MS,
# SECURITY_MODERATION_FAIL_OPEN, SECURITY_AUDIT_LOG_LEVEL, SECRET_KEY (use AUDIT_HMAC_SECRET or AUTH_SECRET)

# =============================================================================
# 附录：旧版 AI 环境变量（迁移用，不推荐新部署）
# -----------------------------------------------------------------------------
# 见 docs/ai-gateway.md#legacy-migration — 未来将移除代码内 id→角色 映射，请改用 AI_PLAYER_ROLE_CHAIN。
# AI_PLAYER_MODEL_CHAIN="deepseek-v3.2,glm-5-air"
# AI_MEMORY_MODEL="deepseek-v3.2"
# AI_ADMIN_MODEL="deepseek-reasoner"

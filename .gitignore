# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Cursor debug NDJSON (local ingest)
.cursor/debug-*.log

# local agent scratch / backups
.claude/
.codex-backup/

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/screenshots/
/videos/
*.webm

# next.js
/.next/
/out/
/dist/

# production
/build

# misc
.DS_Store
Thumbs.db
*.pem

# debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# env files (keep templates)
.env
.env.*
!.env.example
!.env.template
!.env*.example
!.env*.template
!.env.local.oneapi.example

# runtime data
/.runtime-data/
/.local-runtime/
/.ops/autoops/runtime/*
!/.ops/autoops/runtime/.gitkeep
/tmp/
/temp/

# editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json

# local docker volumes / data dirs (defense-in-depth)
pgdata/
postgres_data/
redisdata/
redis_data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
dump.rdb
